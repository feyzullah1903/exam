@using Circle.Areas.AdminPanel.VievModels
@using Circle.Models
@model List<GetVM>
@{
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">People Table</h4>
                <a class="btn btn-success" asp-action="create">Create</a>

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Name
                                </th>
                              
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (GetVM people in Model)
                            {

                                <tr>
                                    <td>
                                        @(++count)
                                    </td>
                                    <td class="py-1">
                                        <img src="~/images/@people.Image" alt="image" />
                                    </td>
                                    <td>
                                        @people.Name
                                    </td>
                                    <td>
                                        <a class="btn btn-info" asp-action="detail" asp-route-id="@people.Id">Detail</a>
                                        <a class="btn btn-warning" asp-action="update" asp-route-id="@people.Id">Update</a>
                                        <a class="btn btn-danger" asp-action="delete" asp-route-id="@people.Id">Delete</a>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

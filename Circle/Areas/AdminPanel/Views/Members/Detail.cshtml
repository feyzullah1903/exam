@using Circle.Models

@model Memmbers
<div class="card" style="width: 18rem;">
    <img class="card-img-top" src="~/images/@Model.Images" alt="Card image cap">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text">@Model.Desc</p>
       
    </div>
</div>